<section class="bg-academy-pink relative min-h-[700px] flex flex-col overflow-visible" data-purpose="hero-header">
  <div class="container mx-auto px-6 pt-12 pb-8 text-center relative z-0">
    <p class="text-modern-sans uppercase tracking-widest text-white text-md font-medium font-bold">Academy</p>
    <hr class="mt-3 mx-auto w-[80%] border-0 border-t-2 border-white/50" aria-hidden="true" />
  </div>
  <div class="container mx-auto px-6 relative z-10 grid md:grid-cols-10 gap-8 items-center flex-1">
    <div class="pt-4 md:pt-0 text-center md:col-span-6">
      <p class="text-modern-sans text-6xl md:text-8xl text-white mb-6">Yael Rodríguez</p>
      <h1 class="text-modern-sans text-xl text-white mb-10 max-w-md leading-relaxed text-center mx-auto">
        Formación integral en belleza: técnica, mentalidad y rentabilidad.
      </h1>
      <a class="btn-outline relative z-30 inline-block text-white text-sm bg-academy-pink/80" href="#contacto" data-cta="hero_reservar">Reserva tu plaza en la próxima convocatoria</a>
    </div>
    <div class="relative flex justify-center -mt-24 z-20 md:col-span-4 self-end h-full overflow-visible">
      <img
        src="https://imagedelivery.net/F646Wun-eua00pA0NmkORQ/a776f436-1ac2-43f5-e108-9a785800bf00/public"
        alt="Yael Rodríguez - Directora Académica"
        class="w-full h-full max-w-lg object-cover object-bottom rounded overflow-clip [overflow-clip-margin:15rem]"
        width="600"
        height="750"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    
  </div>
</section>
