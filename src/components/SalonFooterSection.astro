---
const salonBgUrl = "https://imagedelivery.net/F646Wun-eua00pA0NmkORQ/19ab9392-ac39-400f-24b4-6f4e3170e400/public";
---

<section class="relative h-[600px] overflow-hidden" data-purpose="salon-image">
  <h2 class="sr-only">Nuestro espacio de formación</h2>
  <img
    src={salonBgUrl}
    alt="Academia Yael Rodríguez - interior del salón de formación"
    class="absolute inset-0 w-full h-full object-cover"
    width="1200"
    height="800"
    loading="lazy"
    decoding="async"
  />
  <div class="absolute inset-0 bg-black/40 z-[1]" aria-hidden="true"></div>
  <div class="absolute bottom-12 left-0 right-0 text-center px-4 z-10">
    <p class="text-white text-[10px] md:text-xs tracking-[0.2em] font-bold uppercase drop-shadow-lg">
      Nuestro salón es accesible para sillas de ruedas y scooters de movilidad, con rampas y ascensores para una fácil navegación.
    </p>
  </div>
</section>
