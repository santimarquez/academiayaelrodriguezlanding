---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Aviso Legal - Academia Yael Rodríguez"
  description="Aviso legal de Academia Yael Rodríguez. Información sobre la titularidad del sitio web y condiciones de uso."
>
  <main class="min-h-screen">
    <article class="container mx-auto px-6 py-24 max-w-3xl">
      <h1 class="text-modern-sans text-4xl mb-8">Aviso Legal</h1>
      <div class="prose prose-gray text-modern-sans">
        <p class="text-gray-700 leading-relaxed">
          Contenido del aviso legal en elaboración. La academia Yael Rodríguez es la titular de este sitio web.
        </p>
      </div>
      <p class="mt-12">
        <a href="/" class="text-academy-dark font-semibold hover:underline">← Volver al inicio</a>
      </p>
    </article>
  </main>
</BaseLayout>
