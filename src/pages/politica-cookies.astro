---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Política de Cookies - Academia Yael Rodríguez"
  description="Política de cookies de Academia Yael Rodríguez. Uso de cookies en este sitio web."
>
  <main class="min-h-screen">
    <article class="container mx-auto px-6 py-24 max-w-3xl">
      <h1 class="text-modern-sans text-4xl mb-8">Política de Cookies</h1>
      <div class="prose prose-gray text-modern-sans">
        <p class="text-gray-700 leading-relaxed">
          Contenido de la política de cookies en elaboración. Aquí se describirá el uso de cookies.
        </p>
      </div>
      <p class="mt-12">
        <a href="/" class="text-academy-dark font-semibold hover:underline">← Volver al inicio</a>
      </p>
    </article>
  </main>
</BaseLayout>
