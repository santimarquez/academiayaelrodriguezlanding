---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import PhilosophySection from "../components/PhilosophySection.astro";
import DifferentiationSection from "../components/DifferentiationSection.astro";
import CoursesSection from "../components/CoursesSection.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import CTADecisionSection from "../components/CTADecisionSection.astro";
import AcademicTeamSection from "../components/AcademicTeamSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SalonFooterSection from "../components/SalonFooterSection.astro";
---

<BaseLayout
  title="Yael Rodríguez Academy - Formación Integral en Belleza"
  description="Academia Yael Rodríguez – Formación integral en belleza: uñas, cejas, pestañas y estética. Academia de estética en Vigo. Formamos profesionales preparadas para ejercer y facturar."
  ogImage="https://imagedelivery.net/F646Wun-eua00pA0NmkORQ/a776f436-1ac2-43f5-e108-9a785800bf00/public"
>
  <main id="main-content">
    <HeroSection />
    <PhilosophySection />
    <DifferentiationSection />
    <AcademicTeamSection />
    <CoursesSection />
    <TestimonialsSection />
    <CTADecisionSection />
    <ContactSection />
    <SalonFooterSection />
  </main>
</BaseLayout>
